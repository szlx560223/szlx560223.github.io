<h3 id="3-实例化"><a href="#3-实例化" class="headerlink" title="3.实例化"></a>3.实例化</h3><figure class="highlight typescript"><table><tr><td class="code"><pre><span class="line"><span class="keyword">const</span> newBrick=<span class="title function_">instantiate</span>(<span class="variable language_">this</span>.<span class="property">brick</span>);</span><br><span class="line"><span class="variable language_">this</span>.<span class="property">Node</span>.<span class="title function_">addChild</span>(newBrick);</span><br><span class="line">newBrick.<span class="title function_">setPosition</span>(pos);</span><br></pre></td></tr></table></figure>

<h3 id="4-tween实例"><a href="#4-tween实例" class="headerlink" title="4.tween实例"></a>4.tween实例</h3><figure class="highlight typescript"><table><tr><td class="code"><pre><span class="line"><span class="title function_">tween</span>(<span class="title class_">Node</span>)</span><br><span class="line">        .<span class="title function_">to</span>(<span class="number">20</span>,&#123;<span class="attr">position</span>:<span class="title function_">v3</span>(x,y,z)&#125;)<span class="comment">//花多长时间，做什么</span></span><br><span class="line">        .<span class="title function_">delay</span>(<span class="number">500</span>)<span class="comment">//延迟</span></span><br><span class="line">        .<span class="title function_">start</span>();<span class="comment">//开始</span></span><br></pre></td></tr></table></figure>



]]></content>
